generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  logo           String   @default("")
  whatsappNumber String   @default("")
  address        String   @default("")
  description    String   @default("")
  isActive       Boolean  @default(true)
  plan           String   @default("basico")
  users          StoreUser[]
  categories     Category[]
  products       Product[]
  orders         Order[]
  testimonials   Testimonial[]
  paymentMethods PaymentMethod[]
  mercadoPagoPayments MercadoPagoPayment[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StoreUser {
  id                String   @id @default(cuid())
  email             String
  password          String
  name              String
  phone             String   @default("")
  address           String   @default("")
  role              String   @default("customer")
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders            Order[]
  twoFactorSecret   String?
  twoFactorEnabled  Boolean  @default(false)
  googleId          String?  @unique
  avatar            String?  @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([email, storeId])
  @@index([storeId, role])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String
  image     String   @default("")
  sortOrder Int      @default(0)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[]
  createdAt DateTime @default(now())

  @@index([storeId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String   @default("")
  price       Float
  comparePrice Float?
  image       String   @default("")
  images      String   @default("[]")
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  isFeatured  Boolean  @default(false)
  isNew       Boolean  @default(false)
  discount    Int?
  sizes       String   @default("[]")
  colors      String   @default("[]")
  rating      Float    @default(4.5)
  reviewCount Int      @default(0)
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([slug, storeId])
  @@index([storeId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerPhone   String
  customerAddress String      @default("")
  status          String      @default("pending")
  total           Float
  notes           String      @default("")
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId           String?
  user             StoreUser?    @relation(fields: [userId], references: [id])
  paymentMethodId  String?
  paymentMethod    PaymentMethod? @relation(fields: [paymentMethodId], references: [id])
  mercadoPagoPayment MercadoPagoPayment?
  items            OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([storeId])
  @@index([storeId, createdAt])
  @@index([userId])
}

model OrderItem {
  id           String   @id @default(cuid())
  productId    String
  productName  String
  productImage String
  price        Float
  quantity     Int
  size         String   @default("")
  color        String   @default("")
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([orderId])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("")
  content   String
  rating    Int      @default(5)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PaymentMethod {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  type          String
  name          String
  isActive      Boolean  @default(true)
  qrCode        String   @default("")
  accountNumber String   @default("")
  accountHolder String   @default("")
  bankName      String   @default("")
  sortOrder     Int      @default(0)
  orders        Order[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([storeId])
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  message   String   @default("")
  source    String   @default("landing")
  plan      String   @default("")
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([status])
  @@index([source])
}

model MercadoPagoPayment {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           Order    @relation(fields: [orderId], references: [id])
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  preferenceId    String
  paymentId       String?
  status          String   @default("pending")
  paymentType     String   @default("")
  lastFourDigits  String   @default("")
  installments    Int      @default(1)
  payerEmail      String   @default("")
  payerDocType    String   @default("")
  payerDocNumber  String   @default("")
  metadata        String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([status])
  @@index([paymentId])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique  // e.g. "chat:1.2.3.4" or "login:1.2.3.4"
  count     Int      @default(1)
  windowEnd DateTime  // when the window resets
  createdAt DateTime @default(now())

  @@index([key])
  @@index([windowEnd])
}
