# Turso Cloud Database - Configure these in Vercel Environment Variables
# Get your credentials at https://turso.tech

# The libsql:// URL of your Turso database
TURSO_URL=libsql://your-database-name.region.turso.io

# The auth token from Turso (Settings > API Tokens)
DATABASE_AUTH_TOKEN=your-turso-auth-token-here

# Prisma schema validation (keep as local file path)
DATABASE_URL=file:./dev.db
