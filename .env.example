# ═══════════════════════════════════════════════════════════
# Supabase Configuration
# Payload CMS 3.0 - PostgreSQL Database + Storage
# ═══════════════════════════════════════════════════════════

# ─── SUPABASE CONNECTION ───
# Get these from: Supabase Dashboard > Settings > Database

# Supabase Project URL (e.g. https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (public, safe for client-side)
# Dashboard > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# Supabase Service Role Key (SECRET! Server-side only!)
# Dashboard > Settings > API > Project API keys > service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ─── SUPABASE POSTGRESQL DATABASE ───
# Payload CMS 3.0 uses this as the primary database
#
# Option 1: Direct connection (for serverless/Vercel)
# Dashboard > Settings > Database > Connection string > URI
# Use the "Transaction" or "Session" pooler mode
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Option 2: Alternative DATABASE_URL (fallback)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# ─── APPLICATION ───
NEXT_PUBLIC_APP_URL=https://baby-duvaby.vercel.app

# Payload CMS secret (used for JWT tokens)
PAYLOAD_SECRET=your-random-secret-at-least-32-chars-long

# NextAuth secret (used for session encryption)
NEXTAUTH_SECRET=your-nextauth-secret

# ─── OPTIONAL: Cloudinary (fallback/legacy) ───
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ─── MERCADO PAGO ───
# NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxx
# MP_ACCESS_TOKEN=APP_USR-xxx

# ═══════════════════════════════════════════════════════════
# SETUP STEPS:
#
# 1. Create Supabase project at https://supabase.com
# 2. Go to Settings > Database > Connection string
#    - Copy the "Transaction pooler" URI
#    - Replace [YOUR-PASSWORD] with your database password
#    - Set as SUPABASE_DB_URL
#
# 3. Go to Settings > API
#    - Copy the "anon public" key -> NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - Copy the "service_role secret" key -> SUPABASE_SERVICE_ROLE_KEY
#
# 4. Run the storage setup script:
#    bun run scripts/setup-supabase-storage.ts
#
# 5. Payload will auto-create tables on first startup
#    (or run: npx payload migrate)
#
# 6. In Supabase Dashboard > Table Editor, verify:
#    - store_users, store_pages, content_blocks, media tables exist
#    - store-media bucket exists in Storage
# ═══════════════════════════════════════════════════════════
