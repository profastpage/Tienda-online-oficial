# ─── Database ───────────────────────────────────
# Local SQLite development
DATABASE_URL=file:./dev.db

# Turso Cloud Database (production)
TURSO_URL=libsql://your-database-name.region.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token-here

# ─── Authentication ─────────────────────────────
# IMPORTANT: Change these secrets in production!
JWT_SECRET=change-this-to-a-random-64-char-secret-in-production
INIT_DB_SECRET=change-this-secret-for-database-init
SUPER_ADMIN_SECRET=change-this-secret-for-super-admin-access

# Super Admin credentials
SUPER_ADMIN_EMAIL=admin@tiendaonlineoficial.com
SUPER_ADMIN_PASSWORD=your-secure-password
# Or use pre-hashed password:
# SUPER_ADMIN_PASSWORD_HASH=$2b$10$your-bcrypt-hash-here
# Optional: 2FA secret for super admin (TOTP)
# SUPER_ADMIN_2FA_SECRET=your-totp-secret

# ─── NextAuth (Google OAuth) ────────────────────
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=change-this-to-a-random-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email (Resend API) ────────────────────────
EMAIL_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@tiendaonlineoficial.com

# ─── WhatsApp Contact ───────────────────────────
# WhatsApp number for SaaS landing page & enterprise plan CTA
NEXT_PUBLIC_WHATSAPP_NUMBER=51999999999

# ─── App URL ───────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ─── Cloudinary Image Storage ───────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=unsigned_upload

# ─── MercadoPago ──────────────────────────────
MP_ACCESS_TOKEN=your-mercado-pago-access-token
MP_PUBLIC_KEY=your-mercado-pago-public-key
NEXT_PUBLIC_MP_PUBLIC_KEY=your-mercado-pago-public-key

# ─── Optional ───────────────────────────────────
# NODE_ENV=production
